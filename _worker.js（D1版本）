const ONLINE_CODES = [200, 301, 302, 403, 404, 502, 521, 522];

function getConfig(env) {
  return {
    ARGO: env.ARGO || env.argo || "", 
    BOT_TOKEN: env.BOT_TOKEN || "",
    CHAT_ID: env.CHAT_ID || ""
  };
}

// 统一获取北京时间的字符串
function getBeijingTimeString() {
  return new Intl.DateTimeFormat("zh-CN", {
    timeZone: "Asia/Shanghai",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false
  }).format(new Date());
}

// 解析节点
function parseArgoConfig(text) {
  if (!text) return [];
  return text
    .split("\n")
    .map(v => v.trim())
    .filter(Boolean)
    .map(line => {
      const parts = line.split("-----");
      return {
        name: parts[0]?.trim(),
        domain: parts[1]?.trim()
      };
    })
    .filter(v => v.name && v.domain);
}

// Telegram 发送通知
async function sendTelegram(env, message) {
  if (!env.BOT_TOKEN || !env.CHAT_ID) return false;
  try {
    const url = `https://api.telegram.org/bot${env.BOT_TOKEN}/sendMessage`;
    const resp = await fetch(url, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({
        chat_id: env.CHAT_ID,
        text: message,
        parse_mode: "HTML"
      })
    });
    const data = await resp.json();
    return data.ok;
  } catch (e) {
    console.error(e);
    return false;
  }
}

// 检查单个隧道
async function checkTunnel(domain) {
  try {
    const resp = await fetch(`https://${domain}`, {
      method: "GET",
      redirect: "manual",
      headers: { "User-Agent": "TunnelMonitor/3.0" }
    });
    return {
      online: ONLINE_CODES.includes(resp.status),
      statusCode: resp.status,
      timestamp: Date.now()
    };
  } catch (e) {
    return {
      online: false,
      statusCode: 0,
      error: e.message,
      timestamp: Date.now()
    };
  }
}

// 执行探测并更新 D1 状态
async function processTunnel(env, db, tunnel) {
  const result = await checkTunnel(tunnel.domain);
  const onlineInt = result.online ? 1 : 0;
  const now = Date.now();

  // 1. 更新最新状态表 (UPSERT 语法)
  await db.prepare(`
    INSERT INTO tunnel_status (name, domain, online, status_code, timestamp)
    VALUES (?, ?, ?, ?, ?)
    ON CONFLICT(name) DO UPDATE SET
      domain=excluded.domain,
      online=excluded.online,
      status_code=excluded.status_code,
      timestamp=excluded.timestamp
  `).bind(tunnel.name, tunnel.domain, onlineInt, result.statusCode, now).run();

  // 2. 写入历史流水表
  await db.prepare(`
    INSERT INTO tunnel_history (name, online, timestamp) VALUES (?, ?, ?)
  `).bind(tunnel.name, onlineInt, now).run();

  // 3. 自动清理 7 天前（168小时）的历史数据，防止 D1 膨胀
  const sevenDaysAgo = now - 7 * 24 * 60 * 60 * 1000;
  await db.prepare(`DELETE FROM tunnel_history WHERE timestamp < ?`).bind(sevenDaysAgo).run();

  // 4. 读取上一次的通知状态
  const notifyRow = await db.prepare(`SELECT status FROM tunnel_notify WHERE name = ?`).bind(tunnel.name).first();
  const notified = notifyRow ? notifyRow.status : null;

  // 离线告警
  if (!result.online && notified !== "offline") {
    await sendTelegram(env, `❌ <b>${tunnel.name} 离线告警</b>\n\n🌐 ${tunnel.domain}\n\n状态码：<code>${result.statusCode || "连接失败"}</code>\n\n时间：${getBeijingTimeString()}`);
    await db.prepare(`INSERT INTO tunnel_notify (name, status) VALUES (?, 'offline') ON CONFLICT(name) DO UPDATE SET status='offline'`).bind(tunnel.name).run();
  }

  // 恢复告警
  if (result.online && notified === "offline") {
    await sendTelegram(env, `✅ <b>${tunnel.name} 已恢复上线</b>\n\n🌐 ${tunnel.domain}\n\n状态：<code>${result.statusCode}</code>\n\n时间：${getBeijingTimeString()}`);
    await db.prepare(`INSERT INTO tunnel_notify (name, status) VALUES (?, 'online') ON CONFLICT(name) DO UPDATE SET status='online'`).bind(tunnel.name).run();
  }
}

// 辅助函数：根据 D1 历史生成热力图和在线率
function parseHistoryMetrics(rows) {
  if (!rows || rows.length === 0) return { uptime: "100.0", heat: "⬜" };
  const total = rows.length;
  const onlineCount = rows.filter(r => r.online === 1).length;
  const uptime = ((onlineCount / total) * 100).toFixed(1);
  
  // 最多取最近 168 条生成热力图
  const recentRows = rows.slice(-168);
  const heat = recentRows.map(r => (r.online === 1 ? "🟩" : "🟥")).join("");
  return { uptime, heat };
}

